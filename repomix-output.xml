'use client';

import React, { useState, useEffect, useMemo } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  Truck, 
  MapPin, 
  Calendar as CalendarIcon, 
  Home, 
  ShieldCheck, 
  Clock, 
  Star, 
  CheckCircle2, 
  ArrowRight, 
  Phone, 
