    const leadId = uuidv4();
    const leadData = {
      ...values,
      id: leadId,
      source: "FlowSync Trial Signup",
      timestamp: new Date().toISOString(),
    };

    try {
      await addDoc(collection(firestore, 'leads'), leadData);
      setIsSuccess(true);
      toast({ title: "Account Initialized", description: "Check your inbox for your login credentials." });
