const SteamParticle = ({ i }: { i: number }) => {
  const [randomValues, setRandomValues] = useState<{ duration: number; delay: number; x: number } | null>(null);

  useEffect(() => {
    setRandomValues({
      duration: 2 + Math.random() * 2,
      delay: Math.random() * 2,
      x: -20 + Math.random() * 40
    });
  }, []);

  if (!randomValues) return null;

  return (
    <motion.div
      className="absolute bottom-0 w-8 h-8 bg-white/20 blur-xl rounded-full"
      initial={{ y: 0, x: 0, opacity: 0, scale: 0.5 }}
      animate={{ 
        y: -150, 
        x: randomValues.x,
        opacity: [0, 0.4, 0],
        scale: [0.5, 1.5, 2]
      }}
      transition={{ 
        duration: randomValues.duration, 
        repeat: Infinity, 
        delay: randomValues.delay,
        ease: "easeOut" 
      }}
    />
  );
};

