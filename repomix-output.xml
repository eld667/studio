          src={imagePath}
          alt={mission.title}
          onLoad={handleImageLoad}
          className="w-full h-auto absolute top-0 left-0"
          animate={{ y: isScrolling ? "-85%" : "0%" }}
          transition={{ duration: duration, ease: "linear", type: "tween" }}
