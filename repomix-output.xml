"use client";

import React, { useState, useEffect, useRef } from 'react';
import { motion, AnimatePresence, useScroll, useTransform, useSpring, useMotionValue } from 'framer-motion';
import { 
  Zap, 
  Battery, 
  Wind, 
  Layers, 
  Sun, 
  ShieldCheck, 
  Star, 
  ChevronRight, 
  Play, 
  Maximize2, 
